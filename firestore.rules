rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /articles/{id} {
      allow read: if true;
      allow write: if false;

      // コメント: 閲覧は全員可、投稿はログインユーザー本人名義のみ（500字まで）、
      // 編集・削除は本人のみ。編集で変更できるのは text と updatedAt だけ
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if request.auth != null
          && resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }
    }
    match /daily_summaries/{id} {
      allow read: if true;
      allow write: if false;
    }
    // 自分のコメント一覧（/profile）用のコレクショングループクエリ。
    // 直接パスの公開読み取りとは別に、横断クエリは本人のコメントのみ許可する
    match /{path=**}/comments/{commentId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ユーザープロフィール（表示名・アイコン）。書き込みは本人のみ
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      // お気に入りは本人のみ読み書き可
      match /favorites/{articleId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
