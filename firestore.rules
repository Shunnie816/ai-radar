rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /articles/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /daily_summaries/{id} {
      allow read: if true;
      allow write: if false;
    }
    // ユーザープロフィール（表示名・アイコン）。書き込みは本人のみ
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
